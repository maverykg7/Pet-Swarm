-- Funções de ataque (sem spawn)
local function safeAttackEnemy(enemy, pet)
    if CombatRemote then pcall(CombatRemote.InvokeServer, CombatRemote, "AttackEnemy", enemy, pet) end
end
local function safeCollectFood(food, pet)
    if CollectionRemote then pcall(CollectionRemote.InvokeServer, CollectionRemote, "CollectFood", food, pet) end
end

-- Ataque a inimigos (3 ciclos por zona)
local function attackEnemiesInZone(zoneName, cycles)
    local zone = zoneCache[zoneName]
    if not zone then return end
    local enemiesObj = zone:FindFirstChild("Enemies")
    if not enemiesObj then return end
    for cycle = 1, cycles do
        local enemies = enemiesObj:GetChildren()
        if #enemies == 0 then break end
        local pets = updatePets()
        if #pets == 0 then return end
        for i = 1, math.min(#pets, #enemies) do
            safeAttackEnemy(enemies[i], pets[i])
        end
        if cycle < cycles then task.wait(0.05) end
    end
end

-- Ataque a bosses
local function attackBosses()
    if #activeBosses == 0 then return end
    local pets = updatePets()
    if #pets == 0 then return end
    for _, boss in ipairs(activeBosses) do
        if boss and boss.Parent then
            safeAttackEnemy(boss, pets[1])
            task.wait(config.bossAttackDelay)
        end
    end
end

-- Coleta de comida
local function collectFood()
    for _, fz in ipairs(foodZones) do
        if fz.enabled then
            local zone = zoneCache[fz.zone]
            if zone then
                local foodSpawns = zone:FindFirstChild("FoodSpawns")
                if foodSpawns then
                    local foods = foodSpawns:GetChildren()
                    if #foods > 0 then
                        local pets = updatePets()
                        if #pets > 0 then
                            for fi, food in ipairs(foods) do
                                local pet = pets[((fi-1) % #pets) + 1]
                                safeCollectFood(food, pet)
                            end
                        end
                    end
                end
            end
        end
    end
end

-- Plantio, hatch, nests
local function doPlanting()
    if not config.autoPlant or #eggsSelected == 0 or not PlantRemote then return end
    for _, zone in ipairs(eggsSelected) do
        for _ = 1, 9 do pcall(PlantRemote.FireServer, PlantRemote, zone) end
    end
end
local function doHatching()
    if not config.autoHatch or not HatchRemote then return end
    for _ = 1, 5 do pcall(HatchRemote.FireServer, HatchRemote) end
end
local function doNests()
    if not config.autoNests or not FeedRemote then return end
    local nests = updateNests()
    if nests then
        for _, nest in ipairs(nests:GetChildren()) do
            for _ = 1, 5 do pcall(FeedRemote.FireServer, FeedRemote, nest) end
        end
    end
end

-- Scan de bosses
local function scanBosses()
    if not config.farmBosses then activeBosses = {}; return end
    local new = {}
    for _, name in ipairs(bossList) do
        if bossEnabled[name] then
            local zone = Workspace.Zones:FindFirstChild(bossZoneMap[name])
            if zone then
                local enemies = zone:FindFirstChild("Enemies")
                if enemies then
                    local enemy = enemies:FindFirstChild(name)
                    if enemy then table.insert(new, enemy) end
                end
            end
        end
    end
    activeBosses = new
end

-- Sacrifício
local function sacrificePet(petName)
    if SacrificeRemote then
        local success = pcall(function() SacrificeRemote:InvokeServer("SacrificeWell", petName) end)
        if success then
            game:GetService("StarterGui"):SetCore("SendNotification", { Title = "Sacrifice", Text = petName .. " sacrificed!", Duration = 1 })
        end
    end
end

-- Variáveis de controle
local active = false
local mainThread = nil
local tasks = {}

-- Função para adicionar tarefa
local function addTask(name, func, interval)
    table.insert(tasks, { func = func, interval = interval, nextTime = 0 })
end

-- Loop principal (único)
local function mainLoop()
    while active do
        local now = os.clock()
        for _, task in ipairs(tasks) do
            if now >= task.nextTime then
                local s, e = pcall(task.func)
                if not s then warn("Task error:", e) end
                task.nextTime = now + task.interval
            end
        end
        task.wait(0.05) -- pequeno delay para não sobrecarregar
    end
end

-- Iniciar farm
local function start()
    if active then return end
    active = true
    tasks = {}
    
    -- Pré-carregar zonas
    if ZonesRF then
        pcall(ZonesRF.InvokeServer, ZonesRF, "RequestZoneMap", "Zone12.1")
        pcall(ZonesRF.InvokeServer, ZonesRF, "RequestZoneMap", "SummerEventZone")
        pcall(ZonesRF.InvokeServer, ZonesRF, "RequestZoneMap", "WinterEventZone")
        pcall(ZonesRF.InvokeServer, ZonesRF, "RequestZoneMap", "ElementEventZone1")
    end
    
    scanBosses()
    
    -- Adicionar tarefas com seus intervalos
    addTask("bossScan", scanBosses, 10)
    addTask("bossAttack", function()
        if config.farmBosses and #activeBosses > 0 then attackBosses() end
    end, 0) -- delay 0, mas o próprio attackBosses já tem delay interno
    addTask("enemyAttack", function()
        if config.farmEnemies then
            if enemyEnabled[1] then attackEnemiesInZone("SummerEventZone", 3) end
            if enemyEnabled[2] then attackEnemiesInZone("WinterEventZone", 3) end
            if enemyEnabled[3] then attackEnemiesInZone("Zone12", 3) end
            if enemyEnabled[4] then attackEnemiesInZone("ElementEventZone1", 3) end
        end
    end, config.enemyDelay)
    addTask("foodCollect", function()
        if config.farmFood then collectFood() end
    end, config.foodDelay)
    addTask("plant", doPlanting, config.eggDelay)
    addTask("hatch", doHatching, config.eggDelay)
    addTask("nests", doNests, config.eggDelay)
    
    mainThread = task.spawn(mainLoop)
    
    game:GetService("StarterGui"):SetCore("SendNotification", {
        Title = "GK Hub", Text = "Farm started!", Duration = 3
    })
end

-- Parar farm
local function stop()
    active = false
    if mainThread then task.cancel(mainThread); mainThread = nil end
    activeBosses = {}
    game:GetService("StarterGui"):SetCore("SendNotification", { Title = "GK Hub", Text = "Farm stopped.", Duration = 2 })
end

