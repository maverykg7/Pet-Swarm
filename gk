local function safeAttackEnemy(enemy, pet)
    pcall(CombatRemote.InvokeServer, CombatRemote, "AttackEnemy", enemy, pet)
end
local function safeCollectFood(food, pet)
    pcall(CollectionRemote.InvokeServer, CollectionRemote, "CollectFood", food, pet)
end
local function attackEnemies(enemies)
    local pets = getPets()
    local petCount = #pets
    if petCount == 0 or #enemies == 0 then return end
    for i = 1, petCount do
        local enemy = enemies[((i-1) % #enemies) + 1]
        safeAttackEnemy(enemy, pets[i])
    end
end
local function attackAllEnemies(zoneName, needsRequest)
    if needsRequest then
        pcall(ZonesRF.InvokeServer, ZonesRF, "RequestZoneMap", zoneName)
        task.wait(0.05)
    end
    local zone = getZone(zoneName)
    if zone and zone:FindFirstChild("Enemies") then
        local enemies = zone.Enemies:GetChildren()
        for i, v in ipairs(enemies) do
            enemiesBuffer[i] = v
        end
        for i = #enemies + 1, #enemiesBuffer do
            enemiesBuffer[i] = nil
        end
        attackEnemies(enemiesBuffer)
    end
end
local function attackSpecificEnemy(zoneName, enemyName, needsRequest)
    if needsRequest then
        pcall(ZonesRF.InvokeServer, ZonesRF, "RequestZoneMap", zoneName)
        task.wait(0.05)
    end
    local zone = getZone(zoneName)
    if zone and zone:FindFirstChild("Enemies") then
        local enemy = zone.Enemies:FindFirstChild(enemyName)
        if enemy then
            local pets = getPets()
            for _, pet in ipairs(pets) do
                safeAttackEnemy(enemy, pet)
            end
        end
    end
end
local function attackBosses()
    if #activeBosses == 0 then return end
    local pets = getPets()
    local petCount = #pets
    if petCount == 0 then return end
    for i = 1, petCount do
        local boss = activeBosses[((i-1) % #activeBosses) + 1]
        if boss and boss.Parent then
            safeAttackEnemy(boss, pets[i])
        end
    end
end
local function collectFoodFromZone(zoneName)
    local zone = getZone(zoneName)
    if zone and zone:FindFirstChild("FoodSpawns") then
        local foods = zone.FoodSpawns:GetChildren()
        local pets = getPets()
        local petCount = #pets
        if petCount == 0 or #foods == 0 then return end
        for i = 1, petCount do
            local food = foods[((i-1) % #foods) + 1]
            safeCollectFood(food, pets[i])
        end
    end
end

local function bossesWorker()
