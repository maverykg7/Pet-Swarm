local function updateZoneCache()
    if os.clock() - cache.zonesLastUpdate < cache.zonesUpdateInterval then return end
    for _, z in ipairs(zoneList) do
        local success, result = pcall(function()
            return Workspace.Zones:FindFirstChild(z)
        end)
        if success and result then
            cache.zones[z] = result
        else
            cache.zones[z] = nil
        end
    end
    cache.zonesLastUpdate = os.clock()
end
