local function enemiesWorker()
    while active do
        if config.farmEnemies then
            local anyEnemyActive = false
            for idx, enemy in ipairs(enemyList) do
                if enemyEnabled[idx] then
                    anyEnemyActive = true
                    if enemy.attackAll then
                        attackAllEnemies(enemy.zone, enemy.needsRequest)
                    else
                        attackSpecificEnemy(enemy.zone, enemy.enemy, enemy.needsRequest)
                    end
                end
            end
            if anyEnemyActive then
                task.wait(0.8)
            else
                task.wait(2)
            end
        else
            task.wait(2)
        end
    end
end
local function foodWorker()
    while active do
        if config.farmFood then
            local anyFoodActive = false
            for _, foodZone in ipairs(foodZones) do
                if foodZone.enabled then
                    anyFoodActive = true
                    collectFoodFromZone(foodZone.zone)
                end
            end
            if anyFoodActive then
                task.wait(0.8)
            else
                task.wait(2)
            end
        else
            task.wait(2)
        end
    end
end
local function ultraHatchWorker()
    local lastHatch = 0
    local hatchInterval = config.hatchSpeed
    local hatchCount = 0
    local maxHatchPerCycle = 100
    while active do
        if config.autoHatch then
            local now = os.clock()
            if now - lastHatch >= hatchInterval then
                for i = 1, 10 do
                    pcall(HatchRemote.FireServer, HatchRemote)
                    hatchCount = hatchCount + 1
                    if hatchCount >= maxHatchPerCycle then
                        hatchCount = 0
                        task.wait(0.001)
                    end
                end
                lastHatch = now
            end
        end
        task.wait()
    end
end
local function ultraPlantWorker()
    local lastPlant = 0
    local plantInterval = config.plantSpeed
    local plantCount = 0
    local maxPlantPerCycle = 50
    while active do
        if config.autoPlant and #eggsSelected > 0 then
            local now = os.clock()
            if now - lastPlant >= plantInterval then
                for _, zone in ipairs(eggsSelected) do
                    for _ = 1, 9 do
                        pcall(PlantRemote.FireServer, PlantRemote, zone)
                        plantCount = plantCount + 1
                        if plantCount >= maxPlantPerCycle then
                            plantCount = 0
                            task.wait(0.001)
                        end
                    end
                end
                lastPlant = now
            end
        end
        task.wait()
    end
end
local function ultraNestsWorker()
    local lastNest = 0
    local nestInterval = config.nestsSpeed
    local nestCount = 0
    local maxNestPerCycle = 30
    while active do
        if config.autoNests then
            local now = os.clock()
            if now - lastNest >= nestInterval then
                local nests = getNests()
                if nests then
                    for _, nest in ipairs(nests:GetChildren()) do
                        pcall(FeedRemote.FireServer, FeedRemote, nest)
                        nestCount = nestCount + 1
                        if nestCount >= maxNestPerCycle then
                            nestCount = 0
                            task.wait(0.001)
                        end
                    end
                end
                lastNest = now
            end
        end
        task.wait()
    end
end
local function removeHatchAnimation()
    local ev = ReplicatedStorage and ReplicatedStorage:FindFirstChild("Remotes") 
            and ReplicatedStorage.Remotes:FindFirstChild("Events") 
            and ReplicatedStorage.Remotes.Events:FindFirstChild("HatchAnimationEvent")
    if ev then
        ev:Destroy()
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Animation Removed",
            Text = "HatchAnimationEvent destroyed!",
            Duration = 3
        })
    else
        game:GetService("StarterGui"):SetCore("SendNotification", {
            Title = "Error",
            Text = "HatchAnimationEvent not found.",
            Duration = 3
        })
    end
end
